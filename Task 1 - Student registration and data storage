import java.util.*;

public class Main {

    // Student class inside same file
    static class Student {
        String name, email, dob, dept, phone;

        Student(String name, String email, String dob, String dept, String phone) {
            this.name = name;
            this.email = email;
            this.dob = dob;
            this.dept = dept;
            this.phone = phone;
        }
    }

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);
        ArrayList<Student> list = new ArrayList<>();

        System.out.println("----- Student Registration -----");

        System.out.print("Enter Name: ");
        String name = sc.nextLine();

        System.out.print("Enter Email: ");
        String email = sc.nextLine();

        System.out.print("Enter DOB: ");
        String dob = sc.nextLine();

        System.out.print("Enter Department: ");
        String dept = sc.nextLine();

        System.out.print("Enter Phone: ");
        String phone = sc.nextLine();

        // Store data
        list.add(new Student(name, email, dob, dept, phone));

        System.out.println("\nRegistration Successful!\n");

        // Display data
        System.out.println("----- Student Records -----");
        System.out.printf("%-10s %-20s %-12s %-10s %-12s\n",
                "Name", "Email", "DOB", "Dept", "Phone");

        for (Student s : list) {
            System.out.printf("%-10s %-20s %-12s %-10s %-12s\n",
                    s.name, s.email, s.dob, s.dept, s.phone);
        }
    }
}
